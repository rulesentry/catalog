{
  "$schema": "https://schemas.rulesentry.io/v4/catalog/policy.schema.json",
  "id": "policy.pii-ner",
  "qualified_id": "rulesentry.policy.pii-ner",
  "publisher_id": "rulesentry",
  "type": "policy",
  "version": "4.1.0",
  "status": "active",
  "name": "PII Named Entity Recognition Policy",
  "description": "On-device NER-based PII detection for people, locations, organisations, and miscellaneous entities. All rules require an active ONNX model (distilbert-ner — download in Settings). Rules silently no-op without a model, so this policy is safe to activate at any time.",
  "profiles": [
    "gdpr",
    "ccpa",
    "production"
  ],
  "regions": [
    "GLOBAL"
  ],
  "priority": 50,
  "tags": [
    "pii",
    "ner",
    "ai",
    "on-device"
  ],
  "rules": [
    {
      "rule_id": "ner.person_name",
      "pinned_version": "3.0.0",
      "priority": 60,
      "attached_at": "2026-03-18T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Person name detection via NER — GDPR Art. 4 direct personal identifier"
    },
    {
      "rule_id": "ner.location",
      "pinned_version": "3.0.0",
      "priority": 70,
      "attached_at": "2026-03-18T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Location name detection via NER — PII when combined with other identifiers"
    },
    {
      "rule_id": "ner.organization",
      "pinned_version": "3.0.0",
      "priority": 50,
      "attached_at": "2026-03-18T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Organisation name detection via NER — contextual, lower standalone risk"
    },
    {
      "rule_id": "ner.misc_entity",
      "pinned_version": "3.0.0",
      "priority": 60,
      "attached_at": "2026-03-18T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Miscellaneous named entities via NER — nationalities, events, awards; partial NRP overlap"
    },
    {
      "rule_id": "ner.email",
      "pinned_version": "1.0.0",
      "priority": 55,
      "attached_at": "2026-04-23T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Email detection via OPF's PRIVATE_EMAIL label — complements contact.email_address regex"
    },
    {
      "rule_id": "ner.phone",
      "pinned_version": "1.0.0",
      "priority": 55,
      "attached_at": "2026-04-23T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Phone detection via OPF's PRIVATE_PHONE label — complements contact.phone_* regex"
    },
    {
      "rule_id": "ner.address",
      "pinned_version": "1.0.0",
      "priority": 65,
      "attached_at": "2026-04-23T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Street-address detection via OPF's PRIVATE_ADDRESS label — sibling to ner.location"
    },
    {
      "rule_id": "ner.date",
      "pinned_version": "1.0.0",
      "priority": 40,
      "attached_at": "2026-04-23T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Date detection via OPF's PRIVATE_DATE label — medium severity, prose-friendly"
    },
    {
      "rule_id": "ner.url",
      "pinned_version": "1.0.0",
      "priority": 30,
      "attached_at": "2026-04-23T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "URL detection via OPF's PRIVATE_URL label — low severity, fills gaps in network.url_* regex"
    },
    {
      "rule_id": "ner.secret",
      "pinned_version": "1.0.0",
      "priority": 95,
      "attached_at": "2026-04-23T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Secret/password detection via OPF's SECRET label — OPF hits F1 0.97 on ai4privacy passwords"
    },
    {
      "rule_id": "ner.account_number",
      "pinned_version": "1.0.0",
      "priority": 85,
      "attached_at": "2026-04-23T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Account number detection via OPF's ACCOUNT_NUMBER label — known to over-fire; consider disabling via RuleOverride"
    },
    {
      "rule_id": "personal.labeled_field_name",
      "pinned_version": "1.3.1",
      "priority": 70,
      "attached_at": "2026-03-18T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Pattern fallback for NER misses in labeled form fields (Name: FirstLast)"
    },
    {
      "rule_id": "personal.pronoun_name_reference",
      "pinned_version": "1.0.0",
      "priority": 65,
      "attached_at": "2026-03-18T00:00:00Z",
      "attached_by": "claude-code",
      "notes": "Pronoun + name references (e.g. 'his name is John') — below labeled_field_name, above ner.person_name"
    }
  ],
  "overrides": [
    {
      "rule_id": "ner.person_name",
      "allowlist": [
        "Email",
        "Phone",
        "Name",
        "Date",
        "Address",
        "Subject",
        "Status",
        "Agent",
        "Customer",
        "Channel",
        "Category",
        "Resolution",
        "Title"
      ]
    }
  ],
  "metadata": {
    "frameworks": [
      "GDPR",
      "CCPA",
      "HIPAA"
    ],
    "compliance_scope": "Named entity PII detection via on-device AI models",
    "review_cycle": "quarterly",
    "owner": "compliance-team"
  },
  "origin": {
    "source_type": "local"
  },
  "created_at": "2026-03-18T00:00:00Z",
  "created_by": "claude-code",
  "modified_at": "2026-04-23T00:00:00Z",
  "modified_by": "claude-code"
}
