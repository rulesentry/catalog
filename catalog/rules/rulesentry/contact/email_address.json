{
  "$schema": "https://schemas.rulesentry.io/v4/catalog/rule.schema.json",
  "id": "contact.email_address",
  "qualified_id": "rulesentry.contact.email_address",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "Email Address",
  "description": "Detects email addresses using RFC 5322 compliant pattern. Includes support for international domains (IDN), subdomains, and plus addressing (user+tag@domain.com).",
  "category_id": "contact",
  "severity": "medium",
  "profiles": [
    "gdpr",
    "ccpa",
    "pipeda",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "standard": "RFC 5322",
    "supports": [
      "plus addressing",
      "subdomains",
      "international domains"
    ],
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}\\b",
      "engine": "regex",
      "validator": "tld_reject",
      "validator_params": {
        "reject_tlds": [
          "txt",
          "pdf",
          "doc",
          "docx",
          "xls",
          "xlsx",
          "csv",
          "jpg",
          "jpeg",
          "png",
          "gif",
          "bmp",
          "svg",
          "webp",
          "zip",
          "tar",
          "gz",
          "rar",
          "7z",
          "exe",
          "dll",
          "bat",
          "sh",
          "bin",
          "html",
          "htm",
          "xml",
          "json",
          "yaml",
          "yml",
          "mp3",
          "mp4",
          "avi",
          "mov",
          "wav"
        ]
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[Email-Redacted]"
        }
      },
      "message": "Email address redacted"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.946580Z",
  "regions": [
    "GLOBAL"
  ]
}
