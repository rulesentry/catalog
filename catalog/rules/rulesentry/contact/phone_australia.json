{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "contact.phone_australia",
  "qualified_id": "rulesentry.contact.phone_australia",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "Australian Phone Number",
  "description": "Detects Australian phone numbers including landlines (02, 03, 07, 08) and mobiles (04). Supports +61 international format.",
  "category_id": "contact",
  "severity": "medium",
  "profiles": [
    "privacy-act-au",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "formats": [
      "0X XXXX XXXX",
      "+61 X XXXX XXXX"
    ],
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 65,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:\\+61\\s?|0)[2-478](?:[\\s.-]?\\d{4}){2}\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "TEL",
          "reversible": false
        }
      },
      "message": "Australian phone number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.946580Z",
  "regions": [
    "AU"
  ]
}
