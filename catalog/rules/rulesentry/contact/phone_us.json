{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "contact.phone_us",
  "qualified_id": "rulesentry.contact.phone_us",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "US Phone Number",
  "description": "Detects US phone numbers in various formats. Bare unlabeled numbers require +1 prefix, parenthesized area code, or dash/dot separators to reduce false positives against healthcare IDs (NHS, NPI) and other 10-digit sequences.",
  "category_id": "contact",
  "severity": "medium",
  "profiles": [
    "ccpa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "formats": [
      "(XXX) XXX-XXXX",
      "(XXX)XXX-XXXX",
      "XXX-XXX-XXXX",
      "XXX.XXX.XXXX",
      "+1 XXX XXX XXXX",
      "1-XXX-XXX-XXXX"
    ],
    "pattern_rationale": "Same four-arm strategy as phone_canada: (1) phone keyword label — any NANP format; (2) +1 prefix; (3) 1-NXX-NXX-XXXX dash/dot; (4) (NXX) parenthesized area code; (5) NXX-NXX-XXXX or NXX.NXX.XXXX dash/dot bare. Bare space-separated 3-3-4 is NOT matched without context.",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 65,
    "target": "content",
    "pattern": {
      "pattern": "(?:(?:ph(?:one)?|tel(?:ephone)?|mobile|cell(?:ular)?|call|fax)[:\\s#-]*(?:\\+?1[\\s.-]?)?(?:\\([2-9]\\d{2}\\)[\\s.-]?|[2-9]\\d{2}[\\s.-]?)[0-9]\\d{2}[\\s.-]?\\d{4}|\\+1[\\s.-]?(?:\\([2-9]\\d{2}\\)[\\s.-]?|[2-9]\\d{2}[\\s.-]?)[0-9]\\d{2}[\\s.-]?\\d{4}|1[.-][2-9]\\d{2}[.-]\\d{3}[.-]\\d{4}|\\([2-9]\\d{2}\\)[\\s.-]?[0-9]\\d{2}[\\s.-]?\\d{4}|\\b[2-9]\\d{2}[.-]\\d{3}[.-]\\d{4})\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "TEL",
          "reversible": false
        }
      },
      "message": "US phone number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-04-15T00:00:00Z",
  "regions": [
    "US"
  ]
}
