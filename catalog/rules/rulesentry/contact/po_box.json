{
  "$schema": "https://schemas.rulesentry.io/v4/catalog/rule.schema.json",
  "id": "contact.po_box",
  "qualified_id": "rulesentry.contact.po_box",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "PO Box Address",
  "description": "Detects Post Office Box addresses (e.g., PO Box 123, P.O. Box 456).",
  "category_id": "contact",
  "severity": "low",
  "profiles": [
    "gdpr",
    "ccpa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 60,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:P\\.?\\s?O\\.?|Post\\s+Office)\\s+Box\\s+\\d+\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "inference",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[PO_BOX]"
        }
      },
      "message": "PO Box address redacted"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.946580Z",
  "regions": [
    "GLOBAL"
  ]
}
