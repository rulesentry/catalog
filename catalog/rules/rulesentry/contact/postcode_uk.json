{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "contact.postcode_uk",
  "qualified_id": "rulesentry.contact.postcode_uk",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "3.0.0",
  "name": "UK Postcode",
  "description": "Detects UK postcodes in various formats (e.g., SW1A 1AA, M1 1AE, B33 8TH). Supports all UK postcode patterns including London, Manchester, Birmingham, etc.",
  "category_id": "contact",
  "severity": "low",
  "profiles": [
    "gdpr",
    "uk-dpa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "A(A)N(A/N)(A/N) NAA",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 60,
    "target": "content",
    "pattern": {
      "pattern": "\\b[A-Z]{1,2}\\d[A-Z\\d]?\\s?\\d[A-Z]{2}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "POSTAL",
          "reversible": false
        }
      },
      "message": "UK postcode tokenized, outward code visible for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.946580Z",
  "regions": [
    "UK"
  ]
}
