{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "credentials.assignment_secret",
  "qualified_id": "rulesentry.credentials.assignment_secret",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "1.0.0",
  "status": "active",
  "name": "Assignment Secret",
  "summary": "Detects high-entropy values assigned to credential-named variables",
  "description": "Detects opaque values (24–256 chars, alphanumeric + common secret chars) that appear on the right-hand side of an assignment where the left-hand variable name contains a credential indicator (secret, token, password, passwd, key, apikey, auth, credential). Uses context_radius window to confirm the indicator is nearby rather than baking the keyword into the regex — analogous to OPF's context-aware PII detection.",
  "category_id": "credentials",
  "severity": "high",
  "profiles": [
    "production"
  ],
  "regions": [
    "GLOBAL"
  ],
  "tags": [
    "secret",
    "credential",
    "assignment",
    "context-aware",
    "generic"
  ],
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 65,
    "target": "content",
    "pattern": {
      "pattern": "(?:[=:\\s\"']|\\b)([A-Za-z0-9+/=_\\-]{24,256})(?:[\"'\\s,;\\n]|$)",
      "engine": "regex",
      "flags": {
        "case_insensitive": false,
        "capture_groups": true
      },
      "validator": "context_filter",
      "validator_params": {
        "require_keywords": [
          "secret", "Secret", "SECRET",
          "token", "Token", "TOKEN",
          "password", "Password", "PASSWORD",
          "passwd", "PASSWD",
          "apikey", "api_key", "API_KEY",
          "auth", "Auth", "AUTH",
          "credential", "Credential"
        ],
        "reject_keywords": [
          "example", "placeholder", "your-", "YOUR-", "<", "TODO"
        ],
        "context_radius": 40
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "message": "Credential value redacted",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[SECRET_VALUE]"
        }
      }
    }
  },
  "created_at": "2026-04-23T00:00:00Z",
  "updated_at": "2026-04-23T00:00:00Z"
}
