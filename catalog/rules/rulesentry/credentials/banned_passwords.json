{
  "$schema": "https://schemas.rulesentry.io/v4/catalog/rule.schema.json",
  "id": "credentials.banned_passwords",
  "qualified_id": "rulesentry.credentials.banned_passwords",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "status": "active",
  "name": "Banned Password Detection",
  "summary": "Detects commonly breached passwords appearing in text",
  "description": "List membership rule that checks if any of the most commonly breached passwords appear in the input. Uses case-insensitive matching to catch passwords embedded in configuration files, logs, or documentation.",
  "category_id": "credentials",
  "severity": "high",
  "profiles": [
    "production",
    "security-audit"
  ],
  "regions": [
    "GLOBAL"
  ],
  "tags": [
    "credentials",
    "password",
    "list",
    "breach"
  ],
  "evaluation": {
    "evaluation_type": "list_membership",
    "list": {
      "values": [
        "password123",
        "qwerty123",
        "admin123",
        "letmein",
        "welcome1",
        "monkey123",
        "dragon123",
        "master123",
        "trustno1"
      ],
      "case_sensitive": false
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "message": "Banned password detected — this password appears in known breach databases and must not be used.",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "PWD",
          "reversible": false
        }
      }
    }
  },
  "created_at": "2026-03-09T00:00:00Z",
  "updated_at": "2026-04-15T00:00:00Z"
}
