{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "credentials.bearer_token",
  "qualified_id": "rulesentry.credentials.bearer_token",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "1.0.0",
  "status": "active",
  "name": "Bearer Token",
  "summary": "Detects Bearer tokens in Authorization headers and similar patterns",
  "description": "Detects opaque tokens following the 'Bearer' keyword — captures tokens 20–512 chars long that appear in an Authorization context. The context_radius window ensures the keyword is genuinely nearby, suppressing false positives on standalone 'Bearer' mentions in documentation.",
  "category_id": "credentials",
  "severity": "high",
  "profiles": [
    "production"
  ],
  "regions": [
    "GLOBAL"
  ],
  "tags": [
    "secret",
    "bearer",
    "oauth",
    "authorization",
    "credential"
  ],
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 75,
    "target": "content",
    "pattern": {
      "pattern": "Bearer\\s+([A-Za-z0-9_\\-\\.+/]{20,512})",
      "engine": "regex",
      "flags": {
        "case_insensitive": false,
        "capture_groups": true
      },
      "validator": "context_filter",
      "validator_params": {
        "require_keywords": ["Authorization", "authorization", "Bearer", "bearer", "token"],
        "context_radius": 60
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "message": "Bearer token redacted",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[BEARER_TOKEN]"
        }
      }
    }
  },
  "created_at": "2026-04-23T00:00:00Z",
  "updated_at": "2026-04-23T00:00:00Z"
}
