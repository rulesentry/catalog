{
  "_note": "Overlaps with digital_identity.generic_api_key. The credentials/ version is canonical for secret detection; digital_identity/ version retained for category-based policy inclusion.",
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "credentials.generic_api_key",
  "qualified_id": "rulesentry.credentials.generic_api_key",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "3.0.1",
  "status": "active",
  "name": "Generic API Key",
  "summary": "Detects generic API keys with explicit context (api_key:, apiKey:, x-api-key:)",
  "description": "Detects generic API keys with explicit context (e.g., 'api_key:', 'apiKey:', 'x-api-key:'). 20-64 character alphanumeric strings.",
  "category_id": "credentials",
  "severity": "high",
  "profiles": [
    "production"
  ],
  "regions": [
    "GLOBAL"
  ],
  "tags": [
    "secret",
    "api-key",
    "credential",
    "generic"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "note": "Generic pattern - may need context-specific tuning"
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:api[_-]?key|apiKey|x-api-key)[:\\s=\"']+([A-Za-z0-9_\\-]{20,64})\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true,
        "capture_groups": true
      },
      "validator": "context_filter",
      "validator_params": {
        "reject_keywords": [
          "sk_live_",
          "sk_test_",
          "pk_live_",
          "pk_test_"
        ]
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "message": "API key tokenized with reversible mapping for audit trail",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "APIKEY",
          "reversible": true
        }
      }
    }
  },
  "created_at": "2026-02-10T00:00:00Z",
  "updated_at": "2026-04-18T00:00:00Z"
}
