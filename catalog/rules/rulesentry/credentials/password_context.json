{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "credentials.password_context",
  "qualified_id": "rulesentry.credentials.password_context",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "1.0.1",
  "status": "active",
  "name": "Password (Context-Anchored)",
  "summary": "Detects passwords by keyword context (e.g., 'password: Tr!cky$and2025')",
  "description": "Detects passwords by keyword proximity. Matches values following password-related labels such as 'password:', 'passwd:', 'pwd:', 'passcode:'. Not format-based — relies on label context to identify the sensitive value.",
  "category_id": "credentials",
  "severity": "critical",
  "profiles": [
    "production"
  ],
  "regions": [
    "GLOBAL"
  ],
  "tags": [
    "password",
    "credential",
    "context-anchored"
  ],
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 90,
    "target": "content",
    "pattern": {
      "pattern": "(?:password|passwd|pwd|passcode)[:\\s]+([^\\s,;]{1,128})",
      "engine": "regex",
      "flags": {
        "case_insensitive": true,
        "capture_groups": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "message": "Password redacted — detected by keyword context",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[PASSWORD_REDACTED]"
        }
      }
    }
  },
  "created_at": "2026-03-19T00:00:00Z",
  "updated_at": "2026-04-18T00:00:00Z"
}
