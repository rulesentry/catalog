{
  "_note": "Deprecated in v4.0. Use digital_identity.ssh_private_key (canonical). Scheduled for removal in v4.1. Policy authors: update rule_refs to digital_identity.ssh_private_key.",
  "$schema": "https://schemas.rulesentry.io/v4/catalog/rule.schema.json",
  "id": "credentials.ssh_private_key",
  "qualified_id": "rulesentry.credentials.ssh_private_key",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "status": "deprecated",
  "name": "SSH Private Key",
  "summary": "Detects SSH private keys in RSA, DSA, EC, and OPENSSH formats",
  "description": "Detects SSH private keys (RSA, DSA, EC, OPENSSH formats). Exposure allows unauthorized SSH access to servers.",
  "category_id": "credentials",
  "severity": "critical",
  "profiles": [
    "production"
  ],
  "regions": [
    "GLOBAL"
  ],
  "tags": [
    "secret",
    "ssh",
    "private-key",
    "credential"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "formats": [
      "BEGIN RSA PRIVATE KEY",
      "BEGIN DSA PRIVATE KEY",
      "BEGIN EC PRIVATE KEY",
      "BEGIN OPENSSH PRIVATE KEY"
    ],
    "risk": "Server compromise, unauthorized SSH access",
    "superseded_by": "digital_identity.ssh_private_key",
    "sunset_at": "2026-11-19"
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 100,
    "target": "content",
    "pattern": {
      "pattern": "-----BEGIN (?:RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----[\\s\\S]*?-----END (?:RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "message": "SSH Private Key redacted (critical security risk)",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[SSH_PRIVATE_KEY]"
        }
      }
    }
  },
  "created_at": "2026-02-10T00:00:00Z",
  "updated_at": "2026-04-18T00:00:00Z"
}
