{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "credentials.username_context",
  "qualified_id": "rulesentry.credentials.username_context",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "status": "active",
  "name": "Username (Context-Anchored)",
  "summary": "Detects usernames by keyword context (e.g., 'username: rgarza_nv')",
  "description": "Detects usernames by keyword proximity. Matches values following username-related labels such as 'username:', 'user name:', 'login:', 'user id:'. Not format-based — relies on label context to identify the sensitive value.",
  "category_id": "credentials",
  "severity": "medium",
  "profiles": [
    "production"
  ],
  "regions": [
    "GLOBAL"
  ],
  "tags": [
    "username",
    "credential",
    "context-anchored"
  ],
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 60,
    "target": "content",
    "pattern": {
      "pattern": "(?:username|user\\s*name|login|user\\s*id)[:\\s]+([^\\s,;]{1,128})",
      "engine": "regex",
      "flags": {
        "case_insensitive": true,
        "capture_groups": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "message": "Username redacted — detected by keyword context",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[USERNAME_REDACTED]"
        }
      }
    }
  },
  "created_at": "2026-03-19T00:00:00Z",
  "updated_at": "2026-04-18T00:00:00Z"
}
