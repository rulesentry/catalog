{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "financial.bsb_australia",
  "qualified_id": "rulesentry.financial.bsb_australia",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "BSB Number (Australia)",
  "description": "Detects Australian Bank State Branch (BSB) numbers. Format: XXX-XXX (6 digits).",
  "category_id": "financial",
  "severity": "medium",
  "profiles": [
    "financial-industry",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "XXX-XXX (6 digits)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:bsb)[:\\s]+\\d{3}[-\\s]?\\d{3}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "BSB",
          "reversible": false
        }
      },
      "message": "BSB number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "AU"
  ]
}
