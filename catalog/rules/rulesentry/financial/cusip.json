{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "financial.cusip",
  "qualified_id": "rulesentry.financial.cusip",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "CUSIP (North American Securities Identifier)",
  "description": "Detects CUSIP numbers with checksum validation. CUSIP uniquely identifies North American securities including US and Canadian stocks and bonds.",
  "category_id": "financial",
  "severity": "medium",
  "profiles": [
    "financial-industry",
    "production",
    "sec"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "validator_algorithm": "CUSIP checksum algorithm",
    "standard": "CUSIP Global Services",
    "format": "8 alphanumeric characters + 1 check digit",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 75,
    "target": "content",
    "pattern": {
      "pattern": "\\b[A-Z0-9]{8}\\d\\b",
      "engine": "regex",
      "validator": "cusip_checksum"
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "CUSIP",
          "reversible": false
        }
      },
      "message": "CUSIP tokenized (checksum validated) for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "US",
    "CA"
  ]
}
