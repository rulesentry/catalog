{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "financial.debit_card",
  "qualified_id": "rulesentry.financial.debit_card",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "3.0.1",
  "name": "Debit Card (Luhn Validated)",
  "description": "Detects debit card numbers with Luhn checksum validation. Uses same pattern as credit cards but with debit-specific context detection.",
  "category_id": "financial",
  "severity": "critical",
  "profiles": [
    "financial-industry",
    "pci-dss",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "validator_algorithm": "Luhn checksum (ISO/IEC 7812-1)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 98,
    "target": "content",
    "pattern": {
      "pattern": "(?:debit|checking)\\s+(?:card|account)[:\\s]+(?:\\d{4}[-\\s]?){3}\\d{4}",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      },
      "validator": "luhn",
      "validator_params": {
        "strip_chars": " .-",
        "reject_keywords": [
          "example",
          "test",
          "sample"
        ]
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "CC",
          "reversible": false
        }
      },
      "message": "Debit card tokenized (Luhn validated) per PCI-DSS for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "GLOBAL"
  ]
}
