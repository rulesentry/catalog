{
  "$schema": "https://schemas.rulesentry.io/v4/catalog/rule.schema.json",
  "id": "financial.ifsc_india",
  "qualified_id": "rulesentry.financial.ifsc_india",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "IFSC Code (India)",
  "description": "Detects Indian Financial System Code (IFSC) used for electronic payments. Format: 4 letters (bank) + 0 (reserved) + 6 alphanumeric (branch).",
  "category_id": "financial",
  "severity": "medium",
  "profiles": [
    "financial-industry",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "ABCD0123456 (11 characters)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b[A-Z]{4}0[A-Z0-9]{6}\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "IFSC",
          "reversible": false
        }
      },
      "message": "IFSC code tokenized, bank code and branch suffix visible for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "IN"
  ]
}
