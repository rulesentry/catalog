{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "financial.uk_bank_account",
  "qualified_id": "rulesentry.financial.uk_bank_account",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "3.0.1",
  "name": "UK Bank Account Number",
  "description": "Detects UK bank account numbers. Format: 8 digits preceded by banking context keywords (account number, a/c). UK bank accounts do not have a universal check digit algorithm.",
  "category_id": "financial",
  "severity": "high",
  "profiles": [
    "financial-industry",
    "gdpr",
    "uk-dpa",
    "pci",
    "production"
  ],
  "metadata": {
    "pattern_source": "UK banking account number format",
    "attribution": "UK Payments Administration",
    "format": "8 digits with banking context",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:account\\s+(?:number|no|#)|a\\/c)[:\\s]+\\d{8}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "ACCT",
          "reversible": false
        }
      },
      "message": "UK bank account number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "UK"
  ]
}
