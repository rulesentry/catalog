{
  "$schema": "https://schemas.rulesentry.io/v4/catalog/rule.schema.json",
  "id": "government.africa_nigeria_nin",
  "qualified_id": "rulesentry.government.africa_nigeria_nin",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "Nigerian NIN (National Identification Number)",
  "description": "Detects Nigerian national identification numbers.",
  "category_id": "government",
  "severity": "high",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "country": "Nigeria",
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "11 digits",
    "official_name": "National Identification Number (NIN)",
    "note": "Nigeria Data Protection Regulation (NDPR)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 80,
    "target": "content",
    "pattern": {
      "pattern": "\\b[0-9]{11}\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "NG_NIN",
          "reversible": false
        }
      },
      "message": "Nigeria NIN tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "NG"
  ]
}
