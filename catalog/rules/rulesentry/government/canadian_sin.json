{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "government.canadian_sin",
  "qualified_id": "rulesentry.government.canadian_sin",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "Canadian Social Insurance Number (SIN)",
  "description": "Detects Canadian Social Insurance Numbers with MOD-10 checksum validation. Format: XXX-XXX-XXX (9 digits).",
  "category_id": "government",
  "severity": "critical",
  "profiles": [
    "government-sector",
    "pipeda",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "XXX-XXX-XXX (9 digits)",
    "pattern_rationale": "Two alternatives: (1) with SIN keyword label — separator optional; (2) without label — separator required ([-\\s] not [-\\s]?). Bare 9-digit strings like ABA routing numbers (e.g. 021000021) pass Luhn by coincidence; requiring a dash/space separator when unlabeled eliminates that collision.",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 100,
    "target": "content",
    "pattern": {
      "pattern": "(?:(?:sin|s\\.i\\.n\\.|social\\s+insurance(?:\\s+number)?)[:\\s#-]*\\d{3}[-\\s]?\\d{3}[-\\s]?\\d{3}|\\b\\d{3}[-\\s]\\d{3}[-\\s]\\d{3})\\b",
      "engine": "regex",
      "validator": "canadian_sin_mod10"
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "SIN",
          "reversible": false
        }
      },
      "message": "Canadian SIN tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-04-15T00:00:00Z",
  "regions": [
    "CA"
  ]
}
