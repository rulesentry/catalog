{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "government.ssn_format",
  "qualified_id": "rulesentry.government.ssn_format",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "US Social Security Number (Format Validated)",
  "description": "Detects US Social Security Numbers with format validation. Excludes invalid area/group/serial combinations per SSA rules.",
  "category_id": "government",
  "severity": "critical",
  "profiles": [
    "government-sector",
    "hipaa",
    "ccpa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "validator_algorithm": "SSN format rules (SSA Publication No. 05-10633)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 100,
    "target": "content",
    "pattern": {
      "pattern": "\\b\\d{3}[-\\s]+\\d{2}[-\\s]+\\d{4}\\b",
      "engine": "regex",
      "validator": "ssn_format"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "SSN",
          "reversible": false
        }
      },
      "message": "SSN tokenized (format validated) for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-04-18T00:00:00Z",
  "regions": [
    "US"
  ]
}
