{
  "$schema": "https://schemas.rulesentry.io/v4/catalog/rule.schema.json",
  "id": "ner.email",
  "qualified_id": "rulesentry.ner.email",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "1.0.0",
  "status": "active",
  "name": "Email Address (NER)",
  "description": "Detects email addresses via an active NER provider (OPF's PRIVATE_EMAIL label or equivalent). Complements the regex-based contact.email_address rule: regex wins on formatted cases, NER picks up ambiguous / embedded emails. Rule silently no-ops when no NER provider is active.",
  "category_id": "ner",
  "severity": "high",
  "regions": [
    "GLOBAL"
  ],
  "profiles": [
    "gdpr",
    "ccpa",
    "production"
  ],
  "tags": [
    "pii",
    "email",
    "ner"
  ],
  "evaluation": {
    "evaluation_type": "ner_match",
    "entity_types": [
      "EMAIL_ADDRESS"
    ],
    "confidence_threshold": 0.85,
    "model": {
      "fallback": "skip"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "replace",
        "params": {
          "replacement": "[EMAIL]"
        }
      },
      "message": "Email address detected by NER replaced for de-identification"
    }
  },
  "origin": {
    "source_type": "catalog",
    "catalog_url": "https://catalog.rulesentry.io/rules/rulesentry/ner/email_ner"
  },
  "created_at": "2026-04-23T00:00:00Z",
  "created_by": "claude-code",
  "modified_at": "2026-04-23T00:00:00Z",
  "modified_by": "claude-code"
}
