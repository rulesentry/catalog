{
  "$schema": "https://schemas.rulesentry.io/v4/catalog/rule.schema.json",
  "id": "ner.organization",
  "qualified_id": "rulesentry.ner.organization",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "status": "active",
  "name": "Organisation Name (NER)",
  "description": "Detects organisation names (companies, institutions, government bodies) using an on-device NER model. Requires an active ONNX model (distilbert-ner). Rule silently no-ops when no model is active.",
  "category_id": "ner",
  "severity": "low",
  "regions": [
    "GLOBAL"
  ],
  "profiles": [
    "gdpr",
    "ccpa",
    "production"
  ],
  "tags": [
    "pii",
    "organization",
    "ner"
  ],
  "evaluation": {
    "evaluation_type": "ner_match",
    "entity_types": [
      "ORGANIZATION"
    ],
    "confidence_threshold": 0.85,
    "model": {
      "fallback": "skip"
    },
    "effect": {
      "type": "transform",
      "transform": {
        "type": "replace",
        "params": {
          "replacement": "[ORGANIZATION]"
        }
      }
    }
  },
  "origin": {
    "source_type": "catalog",
    "catalog_url": "https://catalog.rulesentry.io/rules/rulesentry/ner/organization_ner"
  },
