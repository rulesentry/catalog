{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "ner.person_name",
  "qualified_id": "rulesentry.ner.person_name",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "3.0.0",
  "status": "active",
  "name": "Person Name (NER)",
  "description": "Detects full person names using an on-device NER model. Requires an active ONNX model (distilbert-ner). Rules silently no-ops when no model is active.",
  "category_id": "ner",
  "severity": "high",
  "regions": [
    "GLOBAL"
  ],
  "profiles": [
    "gdpr",
    "ccpa",
    "production"
  ],
  "tags": [
    "pii",
    "name",
    "ner"
  ],
  "evaluation": {
    "evaluation_type": "ner_match",
    "entity_types": [
      "PERSON"
    ],
    "confidence_threshold": 0.85,
    "model": {
      "fallback": "skip"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "replace",
        "params": {
          "replacement": "[PERSON]"
        }
      },
      "message": "Person name detected by NER replaced for de-identification"
    }
  },
  "origin": {
    "source_type": "catalog",
    "catalog_url": "https://catalog.rulesentry.io/rules/rulesentry/ner/person_name_ner"
  },
  "created_at": "2026-03-18T00:00:00Z",
  "created_by": "claude-code",
  "modified_at": "2026-03-18T00:00:00Z",
  "modified_by": "claude-code"
}
