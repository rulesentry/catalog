{
  "$schema": "https://schemas.rulesentry.io/v4/catalog/rule.schema.json",
  "id": "ner.phone",
  "qualified_id": "rulesentry.ner.phone",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "1.0.0",
  "status": "active",
  "name": "Phone Number (NER)",
  "description": "Detects phone numbers via an active NER provider (OPF's PRIVATE_PHONE label or equivalent). Complements regex-based contact.phone_* rules for formats our regex doesn't cover or that appear in ambiguous contexts. Rule silently no-ops when no NER provider is active.",
  "category_id": "ner",
  "severity": "high",
  "regions": [
    "GLOBAL"
  ],
  "profiles": [
    "gdpr",
    "ccpa",
    "production"
  ],
  "tags": [
    "pii",
    "phone",
    "ner"
  ],
  "evaluation": {
    "evaluation_type": "ner_match",
    "entity_types": [
      "PHONE_NUMBER"
    ],
    "confidence_threshold": 0.85,
    "model": {
      "fallback": "skip"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "replace",
        "params": {
          "replacement": "[PHONE]"
        }
      },
      "message": "Phone number detected by NER replaced for de-identification"
    }
  },
  "origin": {
    "source_type": "catalog",
    "catalog_url": "https://catalog.rulesentry.io/rules/rulesentry/ner/phone_ner"
  },
