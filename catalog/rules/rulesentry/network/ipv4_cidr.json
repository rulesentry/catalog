{
  "$schema": "https://schemas.rulesentry.io/v4/catalog/rule.schema.json",
  "id": "network.ipv4_cidr",
  "qualified_id": "rulesentry.network.ipv4_cidr",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "IPv4 CIDR Notation",
  "description": "Detects IPv4 addresses with CIDR subnet mask notation (e.g., 192.168.1.0/24).",
  "category_id": "network",
  "severity": "low",
  "profiles": [
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "XXX.XXX.XXX.XXX/XX",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 65,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)/(?:[0-9]|[1-2][0-9]|3[0-2])\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "inference",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "IP",
          "reversible": false
        }
      },
      "message": "IPv4 CIDR notation tokenized, network visible for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.963484Z",
  "regions": [
    "GLOBAL"
  ]
}
