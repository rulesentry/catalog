{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "network.ipv6_cidr",
  "qualified_id": "rulesentry.network.ipv6_cidr",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "3.0.0",
  "name": "IPv6 CIDR Notation",
  "description": "Detects IPv6 addresses with CIDR prefix length notation (e.g., 2001:db8::/32).",
  "category_id": "network",
  "severity": "low",
  "profiles": [
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "IPv6 address/prefix length",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 65,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:(?:[0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}|(?:[0-9a-fA-F]{1,4}:){1,7}:|:(?::[0-9a-fA-F]{1,4}){1,7}|(?:[0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4}|::)/(?:[0-9]|[1-9][0-9]|1[0-1][0-9]|12[0-8])\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "inference",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "IP",
          "reversible": false
        }
      },
      "message": "IPv6 CIDR notation tokenized, network prefix visible for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.963484Z",
  "regions": [
    "GLOBAL"
  ]
}
