{
  "$schema": "https://schemas.rulesentry.io/v4/catalog/rule.schema.json",
  "id": "network.port_number",
  "qualified_id": "rulesentry.network.port_number",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "name": "Port Number (with context)",
  "description": "Detects TCP/UDP port numbers with explicit context (e.g., 'port 8080', 'hostname:3306'). Bare :PORT form requires a hostname-like prefix to avoid matching hex octet fragments (SSH fingerprints, IPv6 segments).",
  "category_id": "network",
  "severity": "info",
  "profiles": [
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 55,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:port|Port)[:\\s]+\\d{1,5}\\b|[a-zA-Z][a-zA-Z0-9._-]*:[1-9][0-9]{1,4}(?:[ \\t\\n\\r]|/|$)",
      "engine": "regex"
    },
    "effect": {
      "type": "info",
      "message": "Port number detected (informational only)"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-04-15T00:00:00Z",
  "regions": [
    "GLOBAL"
  ]
}
