{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "network.ssl_certificate_serial",
  "qualified_id": "rulesentry.network.ssl_certificate_serial",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "3.0.0",
  "name": "SSL/TLS Certificate Serial Number",
  "description": "Detects SSL/TLS certificate serial numbers with explicit context. Hexadecimal format.",
  "category_id": "network",
  "severity": "low",
  "profiles": [
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 60,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:Serial\\s+Number|Certificate\\s+Serial)[:\\s]+(?:[0-9A-Fa-f]{2}[:\\s]?){8,20}[0-9A-Fa-f]{2}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "inference",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "CERT",
          "reversible": false
        }
      },
      "message": "SSL certificate serial tokenized, suffix visible for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.963484Z",
  "regions": [
    "GLOBAL"
  ]
}
