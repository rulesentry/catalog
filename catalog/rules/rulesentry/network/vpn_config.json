{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "network.vpn_config",
  "qualified_id": "rulesentry.network.vpn_config",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "3.0.0",
  "name": "VPN Configuration",
  "description": "Detects VPN configuration identifiers with context (e.g., 'VPN Server:', 'VPN Gateway:'). May contain sensitive network information.",
  "category_id": "network",
  "severity": "medium",
  "profiles": [
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 65,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:VPN\\s+(?:Server|Gateway|Endpoint|Config|Connection))[:\\s]+[A-Za-z0-9._:-]+\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "inference",
      "transform": {
        "type": "replace",
        "params": {
          "replacement": "[VPN_CONFIG]"
        }
      },
      "message": "VPN configuration replaced"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.963484Z",
  "regions": [
    "GLOBAL"
  ]
}
