{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "personal.age_range",
  "qualified_id": "rulesentry.personal.age_range",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "3.0.0",
  "name": "Age Range",
  "description": "Detects age ranges (e.g., 25-35 years old, ages 40-50). Used for demographic analysis but considered PII under some regulations.",
  "category_id": "personal",
  "severity": "low",
  "profiles": [
    "gdpr",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 65,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:ages?|age\\s+range)[:\\s]+\\d{1,3}[-–]\\d{1,3}(?:\\s+years?(?:\\s+old)?)?\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "inference",
      "transform": {
        "type": "replace",
        "params": {
          "replacement": "[AGE_RANGE]"
        }
      },
      "message": "Age range replaced"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.987271Z",
  "regions": [
    "GLOBAL"
  ]
}
