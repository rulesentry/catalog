{
  "$schema": "https://schemas.rulesentry.io/schema/v4/catalog/rule.schema.json",
  "id": "personal.date_of_birth_eu",
  "qualified_id": "rulesentry.personal.date_of_birth_eu",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "4.0.0",
  "status": "active",
  "name": "Date of Birth (EU)",
  "summary": "Detects EU-formatted dates of birth with explicit DOB context markers",
  "description": "Detects dates of birth in EU-common formats including DD/MM/YYYY, DD.MM.YYYY, and YYYY-MM-DD. Requires explicit context markers like 'DOB:', 'Date of Birth:', 'Geburtsdatum:', or 'Date de naissance:'. Designed for GDPR compliance in EU jurisdictions.",
  "category_id": "personal",
  "severity": "high",
  "profiles": [
    "gdpr",
    "production"
  ],
  "regions": [
    "EU"
  ],
  "tags": [
    "pii",
    "date",
    "personal-identifier",
    "gdpr"
  ],
  "metadata": {
    "pattern_source": "Adapted from OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "formats": [
      "DD/MM/YYYY",
      "DD.MM.YYYY",
      "YYYY-MM-DD"
    ],
    "compliance_notes": "DOB is personal data under GDPR Article 4(1)",
    "false_positive_notes": "Requires explicit DOB context to avoid matching generic dates"
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 75,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:DOB|Date\\s+of\\s+Birth|Born|Birthday|Geburtsdatum|Date\\s+de\\s+naissance|D\\.O\\.B\\.?)[:\\s]+(?:\\d{1,2}[/.-]\\d{1,2}[/.-]\\d{2,4}|\\d{4}[/-]\\d{1,2}[/-]\\d{1,2}|(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*\\.?\\s+\\d{1,2},?\\s+\\d{4})\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true,
        "unicode": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "message": "Date of birth redacted per GDPR Article 5(1)(c) data minimisation",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[DATE_OF_BIRTH]"
        }
      }
    }
  },
  "created_at": "2026-02-10T00:00:00Z",
  "updated_at": "2026-03-10T00:00:00Z"
}
