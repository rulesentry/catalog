{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.rulesentry.io/schema/v3/core/semver.schema.json",
  "title": "Semantic Version",
  "description": "Semantic versioning string following the Semver 2.0.0 specification (https://semver.org/). Format: MAJOR.MINOR.PATCH[-PRERELEASE][+BUILD]. Examples: '1.0.0', '2.1.3-beta.1', '1.0.0+build.123'",
  "type": "string",
  "minLength": 5,
  "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
  "examples": [
    "1.0.0",
    "2.3.1",
    "1.0.0-alpha",
    "1.0.0-alpha.1",
    "1.0.0-beta.2",
    "1.0.0-rc.1",
    "2.0.0-rc.2+build.1848",
    "1.0.0+20130313144700",
    "3.1.0-beta.1+git.abc123"
  ]
}
