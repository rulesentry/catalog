{
  "$schema": "../../json-schema/policy.schema.json",
  "id": "policy.secrets-global",
  "qualified_id": "core.policy.secrets-global",
  "type": "policy",
  "version": "1.0.0",
  "status": "active",
  "name": "Global Secrets Detection Policy",
  "description": "Global policy for detecting and protecting credentials, API keys, tokens, and other secrets. Includes all rules from the credentials and digital_identity categories. All credential leaks are elevated to CRITICAL severity.",
  "profiles": [
    "production"
  ],
  "regions": [
    "GLOBAL"
  ],
  "priority": 95,
  "tags": [
    "secrets",
    "credentials",
    "security",
    "global"
  ],
  "rule_categories": [
    {
      "category_id": "credentials",
      "mode": "all"
    },
    {
      "category_id": "digital_identity",
      "mode": "all"
    }
  ],
  "overrides": [
    {
      "rule_id": "credentials.*",
      "severity": "critical",
      "reason": "All credential leaks are critical security incidents regardless of individual rule severity"
    }
  ],
  "metadata": {
    "frameworks": ["NIST 800-53", "SOC 2", "ISO 27001"],
    "compliance_scope": "Global secrets and credential protection",
    "review_cycle": "monthly",
    "owner": "security-team"
  },
  "origin": {
    "source_type": "local"
  },
  "created_at": "2026-02-10T00:00:00Z",
  "created_by": "claude-code",
  "modified_at": "2026-02-10T00:00:00Z",
  "modified_by": "claude-code"
}
