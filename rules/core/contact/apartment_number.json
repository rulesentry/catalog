{
  "$schema": "../../../json-schema/rule.schema.json",
  "id": "contact.apartment_number",
  "qualified_id": "core.contact.apartment_number",
  "type": "rule",
  "version": "3.0.0",
  "name": "Apartment/Unit Number",
  "description": "Detects apartment, unit, or suite numbers (e.g., Apt 123, Unit 4B, Suite 500).",
  "category_id": "contact",
  "rule_kind": "atomic",
  "severity": "low",
  "profiles": [
    "gdpr",
    "ccpa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 55,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:Apt|Apartment|Unit|Suite|Ste|#)[\\.\\s]*[A-Z]?\\d+[A-Z]?\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "inference",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[UNIT]"
        }
      },
      "message": "Apartment/unit number redacted"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.946580Z",
  "regions": [
    "GLOBAL"
  ]
}
