{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "contact.phone_china",
  "qualified_id": "core.contact.phone_china",
  "type": "rule",
  "version": "3.0.0",
  "name": "Chinese Phone Number",
  "description": "Detects Chinese phone numbers with +86 country code. Includes mobile (11 digits starting with 1) and landline formats.",
  "category_id": "contact",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "+86 1XX XXXX XXXX",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 65,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:\\+86[\\s.-]?)?1[3-9]\\d{9}\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "mask",
        "params": {
          "mask_char": "*",
          "visible_suffix": 4,
          "preserve_format": true
        }
      },
      "message": "Chinese phone number masked, last 4 digits visible"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.946580Z",
  "regions": [
    "CN"
  ]
}
