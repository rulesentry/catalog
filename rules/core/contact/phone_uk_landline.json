{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "contact.phone_uk_landline",
  "qualified_id": "core.contact.phone_uk_landline",
  "type": "rule",
  "version": "3.0.0",
  "name": "UK Landline Phone Number",
  "description": "Detects UK landline phone numbers including London (020), Birmingham (0121), Manchester (0161), and other geographic area codes.",
  "category_id": "contact",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "gdpr",
    "uk-dpa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "formats": [
      "020 XXXX XXXX (London)",
      "0XXX XXX XXXX (other)"
    ],
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 65,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:\\+44\\s?(?:1|2)|0(?:1|2))(?:\\d{3}[\\s.-]?\\d{6}|\\d{9})\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "TEL",
          "reversible": false
        }
      },
      "message": "UK landline number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.946580Z",
  "regions": [
    "UK"
  ]
}
