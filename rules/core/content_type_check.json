{
  "$schema": "../../json-schema/rule.schema.json",
  "id": "content_type_check",
  "qualified_id": "core.content_type_check",
  "type": "rule",
  "version": "1.0.0",
  "status": "active",
  "name": "Content Type Check",
  "summary": "Blocks content when metadata indicates HTML content type",
  "description": "Metadata-based rule that triggers when the content_type metadata field equals text/html. Used to flag potentially unsafe HTML content for additional scrutiny.",
  "rule_kind": "atomic",
  "severity": "low",
  "profiles": ["production"],
  "regions": ["GLOBAL"],
  "tags": ["metadata", "content-type", "html"],
  "evaluation": {
    "evaluation_type": "metadata_check",
    "field": "content_type",
    "condition": {
      "operator": "equals",
      "value": "text/html",
      "case_sensitive": false
    },
    "effect": {
      "type": "block",
      "rationale": "safety",
      "message": "HTML content detected via metadata — requires additional review"
    }
  },
  "origin": {
    "source_type": "local"
  },
  "created_at": "2026-02-10T00:00:00Z",
  "created_by": "claude-code",
  "modified_at": "2026-02-10T00:00:00Z",
  "modified_by": "claude-code"
}
