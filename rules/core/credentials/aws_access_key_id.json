{
  "_note": "Overlaps with digital_identity.aws_access_key_id. The credentials/ version is canonical for secret detection; digital_identity/ version retained for category-based policy inclusion.",
  "$schema": "../../../json-schema/rule.schema.json",
  "id": "credentials.aws_access_key_id",
  "qualified_id": "core.credentials.aws_access_key_id",
  "type": "rule",
  "version": "1.0.0",
  "status": "active",
  "name": "AWS Access Key ID",
  "summary": "Detects AWS Access Key IDs starting with AKIA prefix",
  "description": "Detects Amazon Web Services (AWS) Access Key IDs. Format: AKIA followed by 16 alphanumeric characters. Exposure can lead to unauthorized access to AWS resources.",
  "category_id": "credentials",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": ["production"],
  "regions": ["GLOBAL"],
  "tags": ["secret", "cloud", "aws", "credential"],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "AKIA[A-Z0-9]{16}",
    "risk": "Complete AWS account compromise"
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 100,
    "target": "content",
    "pattern": {
      "pattern": "\\bAKIA[A-Z0-9]{16}\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "message": "AWS Access Key ID redacted - must never be exposed (critical security risk)",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[AWS_ACCESS_KEY_ID]"
        }
      }
    }
  },
  "origin": {
    "source_type": "catalog",
    "catalog_url": "https://catalog.rulesentry.io/core/credentials"
  },
  "created_at": "2026-02-10T00:00:00Z",
  "created_by": "rulesentry-catalog",
  "modified_at": "2026-02-10T00:00:00Z",
  "modified_by": "claude-code"
}
