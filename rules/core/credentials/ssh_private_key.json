{
  "_note": "Overlaps with digital_identity.ssh_private_key. The credentials/ version is canonical for secret detection; digital_identity/ version retained for category-based policy inclusion.",
  "$schema": "../../../json-schema/rule.schema.json",
  "id": "credentials.ssh_private_key",
  "qualified_id": "core.credentials.ssh_private_key",
  "type": "rule",
  "version": "1.0.0",
  "status": "active",
  "name": "SSH Private Key",
  "summary": "Detects SSH private keys in RSA, DSA, EC, and OPENSSH formats",
  "description": "Detects SSH private keys (RSA, DSA, EC, OPENSSH formats). Exposure allows unauthorized SSH access to servers.",
  "category_id": "credentials",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": ["production"],
  "regions": ["GLOBAL"],
  "tags": ["secret", "ssh", "private-key", "credential"],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "formats": ["BEGIN RSA PRIVATE KEY", "BEGIN DSA PRIVATE KEY", "BEGIN EC PRIVATE KEY", "BEGIN OPENSSH PRIVATE KEY"],
    "risk": "Server compromise, unauthorized SSH access"
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 100,
    "target": "content",
    "pattern": {
      "pattern": "-----BEGIN (?:RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "message": "SSH Private Key redacted (critical security risk)",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[SSH_PRIVATE_KEY]"
        }
      }
    }
  },
  "origin": {
    "source_type": "catalog",
    "catalog_url": "https://catalog.rulesentry.io/core/credentials"
  },
  "created_at": "2026-02-10T00:00:00Z",
  "created_by": "rulesentry-catalog",
  "modified_at": "2026-02-10T00:00:00Z",
  "modified_by": "claude-code"
}
