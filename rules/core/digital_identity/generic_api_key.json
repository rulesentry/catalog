{
  "_note": "Overlaps with credentials.generic_api_key. The credentials/ version is canonical for secret detection; this version retained for category-based policy inclusion.",
  "$schema": "../../../json-schema/rule.schema.json",
  "id": "digital_identity.generic_api_key",
  "qualified_id": "core.digital_identity.generic_api_key",
  "type": "rule",
  "version": "3.0.0",
  "name": "Generic API Key",
  "description": "Detects generic API keys with explicit context (e.g., 'api_key:', 'apiKey:', 'x-api-key:'). 20-64 character alphanumeric strings.",
  "category_id": "digital_identity",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "note": "Generic pattern - may need context-specific tuning",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:api[_-]?key|apiKey|x-api-key)[:\\s=\"']+[A-Za-z0-9_\\-]{20,64}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      },
      "validator": "context_filter",
      "validator_params": {
        "reject_keywords": [
          "sk_live_",
          "sk_test_",
          "pk_live_",
          "pk_test_"
        ]
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "APIKEY",
          "reversible": true
        }
      },
      "message": "API key tokenized with reversible mapping for audit trail"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:38:02.353727Z",
  "regions": [
    "GLOBAL"
  ]
}
