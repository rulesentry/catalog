{
  "$schema": "../../json-schema/rule.schema.json",
  "id": "file_extension_check",
  "qualified_id": "core.file_extension_check",
  "type": "rule",
  "version": "1.0.0",
  "status": "active",
  "name": "PDF File Extension Check",
  "summary": "Detects PDF files via metadata source filename",
  "description": "Metadata-based rule that triggers when the source filename ends with .pdf. Uses dot-notation path traversal (source.filename) to access nested metadata.",
  "rule_kind": "atomic",
  "severity": "low",
  "profiles": ["production"],
  "regions": ["GLOBAL"],
  "tags": ["metadata", "file-extension", "pdf"],
  "evaluation": {
    "evaluation_type": "metadata_check",
    "field": "source.filename",
    "condition": {
      "operator": "ends_with",
      "value": ".pdf",
      "case_sensitive": false
    },
    "effect": {
      "type": "block",
      "rationale": "safety",
      "message": "PDF file detected via metadata — flagged for document inspection"
    }
  },
  "origin": {
    "source_type": "local"
  },
  "created_at": "2026-02-10T00:00:00Z",
  "created_by": "claude-code",
  "modified_at": "2026-02-10T00:00:00Z",
  "modified_by": "claude-code"
}
