{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.americas_colombia_cc",
  "qualified_id": "core.government.americas_colombia_cc",
  "type": "rule",
  "version": "3.1.0",
  "name": "Colombian Citizenship Card (C\u00e9dula de Ciudadan\u00eda)",
  "description": "Detects Colombian national ID card numbers. Dot-separated form requires a keyword label (cc, c\u00e9dula, etc.) because 3-octet IPv4 prefixes (e.g. 192.168.100) match the same pattern.",
  "category_id": "government",
  "severity": "high",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "country": "Colombia",
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "8-10 digits (formatted with dots or spaces)",
    "official_name": "C\u00e9dula de Ciudadan\u00eda",
    "note": "Law 1581 Personal Data Protection",
    "pattern_rationale": "Two arms: (1) with cc/c\u00e9dula/documento label \u2014 any separator including dots; (2) without label \u2014 comma or space separator only (dots excluded to prevent IPv4 collision e.g. 192.168.100).",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 80,
    "target": "content",
    "pattern": {
      "pattern": "(?:(?:cc|c\\.c\\.|c\\.c|c\\.i\\.|c\\.i|c[e\u00e9]dula(?:\\s*de\\s*ciudadan[\u00edi]a)?|documento)[:\\s#-]*[0-9]{1,3}[.,\\s]?[0-9]{3}[.,\\s]?[0-9]{3}|\\b[0-9]{1,3}[,\\s][0-9]{3}[,\\s][0-9]{3}\\b)",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "CO_CC",
          "reversible": false
        }
      },
      "message": "Colombia CC tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-04-15T00:00:00Z",
  "regions": [
    "CO"
  ]
}
