{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "network.dns_record",
  "qualified_id": "rulesentry.network.dns_record",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "3.0.0",
  "name": "DNS Record",
  "description": "Detects DNS record entries with context (e.g., 'DNS:', 'Nameserver:'). May reveal internal infrastructure.",
  "category_id": "network",
  "severity": "low",
  "profiles": [
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 55,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:DNS|Nameserver|NS)[:\\s]+(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "inference",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "DNS",
          "reversible": false
        }
      },
      "message": "DNS server IP tokenized, first two octets visible for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.963484Z",
  "regions": [
    "GLOBAL"
  ]
}
