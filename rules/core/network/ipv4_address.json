{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "network.ipv4_address",
  "qualified_id": "core.network.ipv4_address",
  "type": "rule",
  "version": "3.0.0",
  "name": "IPv4 Address",
  "description": "Detects IPv4 addresses in dotted decimal notation (e.g., 192.168.1.1). Can be considered personal data under GDPR when linked to individuals.",
  "category_id": "network",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "gdpr",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "XXX.XXX.XXX.XXX",
    "note": "GDPR considers IP addresses as personal data",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "mask",
        "params": {
          "mask_char": "*",
          "visible_prefix": 7
        }
      },
      "message": "IPv4 address masked (GDPR), first two octets visible"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.963484Z",
  "regions": [
    "GLOBAL"
  ]
}
