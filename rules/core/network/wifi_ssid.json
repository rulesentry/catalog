{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "network.wifi_ssid",
  "qualified_id": "core.network.wifi_ssid",
  "type": "rule",
  "version": "3.0.0",
  "name": "WiFi SSID",
  "description": "Detects WiFi network names (SSID) with explicit context (e.g., 'SSID:', 'Network Name:'). May reveal location information.",
  "category_id": "network",
  "severity": "low",
  "profiles": [
    "gdpr",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "note": "SSIDs can be used for geolocation",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 60,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:SSID|Network\\s+Name)[:\\s]+[A-Za-z0-9_-]{2,32}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "inference",
      "transform": {
        "type": "replace",
        "params": {
          "replacement": "[WIFI_SSID]"
        }
      },
      "message": "WiFi SSID replaced"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.963484Z",
  "regions": [
    "GLOBAL"
  ]
}
