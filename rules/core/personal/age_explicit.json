{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "personal.age_explicit",
  "qualified_id": "core.personal.age_explicit",
  "type": "rule",
  "version": "3.0.0",
  "name": "Age (Explicit Mention)",
  "description": "Detects explicit age mentions with 'age:', 'years old', or similar context. Helps identify age-related PII.",
  "category_id": "personal",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "hipaa",
    "gdpr",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:age|aged)[:\\s]+\\d{1,3}(?:\\s+years?\\s+old)?\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "replace",
        "params": {
          "replacement": "[AGE]"
        }
      },
      "message": "Age replaced"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.987271Z",
  "regions": [
    "GLOBAL"
  ]
}
