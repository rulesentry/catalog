{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "personal.date_of_birth",
  "qualified_id": "rulesentry.personal.date_of_birth",
  "publisher_id": "rulesentry",
  "type": "rule",
  "version": "3.0.0",
  "name": "Date of Birth",
  "description": "Detects dates of birth in various formats including MM/DD/YYYY, DD/MM/YYYY, YYYY-MM-DD, and Month DD, YYYY. Includes explicit 'DOB:', 'Date of Birth:', or 'Born:' context.",
  "category_id": "personal",
  "severity": "high",
  "profiles": [
    "hipaa",
    "gdpr",
    "ccpa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "formats": [
      "MM/DD/YYYY",
      "DD/MM/YYYY",
      "YYYY-MM-DD",
      "Month DD, YYYY"
    ],
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 75,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:DOB|Date\\s+of\\s+Birth|Born)[:\\s]+(?:\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4}|\\d{4}[/-]\\d{1,2}[/-]\\d{1,2}|(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*\\s+\\d{1,2},?\\s+\\d{4})\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[DATE_OF_BIRTH]"
        }
      },
      "message": "Date of birth redacted per HIPAA/GDPR"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.987271Z",
  "regions": [
    "GLOBAL"
  ]
}
