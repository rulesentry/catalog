{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "personal.gender_marker",
  "qualified_id": "core.personal.gender_marker",
  "type": "rule",
  "version": "3.0.0",
  "name": "Gender Marker",
  "description": "Detects explicit gender markers with context (e.g., 'Gender: Male', 'Sex: F'). Considered sensitive personal data under GDPR Article 9.",
  "category_id": "personal",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "hipaa",
    "gdpr",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "note": "GDPR Article 9 - special category data",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:Gender|Sex)[:\\s]+(?:Male|Female|M|F|Non-binary|Other|Prefer\\s+not\\s+to\\s+say)\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "replace",
        "params": {
          "replacement": "[GENDER]"
        }
      },
      "message": "Gender marker replaced per GDPR Article 9"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-01-27T19:52:26.987271Z",
  "regions": [
    "GLOBAL"
  ]
}
