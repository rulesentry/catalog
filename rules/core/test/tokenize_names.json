{
  "$schema": "../../../json-schema/rule.schema.json",
  "id": "test.tokenize_names",
  "qualified_id": "core.test.tokenize_names",
  "type": "rule",
  "version": "3.0.0",
  "created_at": "2026-02-02T00:00:00Z",
  "name": "Tokenize Person Names",
  "category_id": "test",
  "rule_kind": "atomic",
  "severity": "medium",
  "evaluation": {
    "evaluation_type": "pattern_match",
    "pattern": {
      "pattern": "\\b[A-Z][a-z]+ [A-Z][a-z]+\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "NAME",
          "reversible": true
        }
      }
    }
  },
  "status": "active",
  "regions": [
    "GLOBAL"
  ]
}
